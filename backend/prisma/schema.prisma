generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String     @id @default(uuid())
  name        String
  email       String     @unique
  password    String
  role        String     @default("user") // "user", "admin", "partner"
  preferences Json?      // E.g., ['hair', 'facial']
  favorites   String[]   // Array of salon IDs
  diagnostics Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  isActive    Boolean    @default(true)

  bookings    Booking[]
  reviews     Review[]
}

model Salon {
  id            String     @id @default(uuid())
  name          String
  city          String
  rating        Float      @default(0.0)
  reviewsCount  Int        @default(0)
  priceCategory String
  trending      Boolean    @default(false)
  description   String
  address       String
  workingHours  String
  imageTheme    String
  coordinates   Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  stylists      Stylist[]
  services      Service[]
  bookings      Booking[]
  reviews       Review[]
}

model Stylist {
  id        String     @id @default(uuid())
  name      String
  specialty String
  rating    Float      @default(0.0)
  salonId   String
  salon     Salon      @relation(fields: [salonId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  bookings  Booking[]
}

model Service {
  id        String     @id @default(uuid())
  name      String
  category  String
  price     Float
  duration  Int        // in minutes
  salonId   String
  salon     Salon      @relation(fields: [salonId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  bookingItems BookingService[]
}

model Booking {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  salonId     String
  salon       Salon      @relation(fields: [salonId], references: [id], onDelete: Cascade)
  stylistId   String?
  stylist     Stylist?   @relation(fields: [stylistId], references: [id], onDelete: SetNull)
  
  totalPrice  Float
  bookingDate String
  bookingTime String
  status      String     @default("Confirmed") // Confirmed, Completed, Cancelled, Waitlisted
  canReview   Boolean    @default(false)
  reviewed    Boolean    @default(false)
  reviewRating Int?
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  services    BookingService[]
}

model BookingService {
  id        String     @id @default(uuid())
  bookingId String
  booking   Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  price     Float
}

model Review {
  id        String     @id @default(uuid())
  author    String
  rating    Float
  comment   String
  date      String
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  salonId   String
  salon     Salon      @relation(fields: [salonId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Waitlist {
  id          String     @id @default(uuid())
  userId      String
  userEmail   String
  salonId     String
  status      String     @default("Waitlisted")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
